      <div class="gallery-track" id="gallery-track"></div>
      <button class="gallery-btn gallery-next" onclick="galleryMove(1)">&#8250;</button>
      <div class="gallery-dots" id="gallery-dots"></div>
    </div>
    <div class="modal-content">
      <span id="modal-badge-top" class="modal-badge"></span>
      <h2 id="modal-title" class="modal-title"></h2>
      <div id="modal-brand" class="modal-brand-sub"></div>
      <div class="modal-prices">
        <span id="modal-price-mxn" class="modal-price-mxn"></span>
        <span id="modal-price-usd" class="modal-price-usd"></span>
      </div>
      <p id="modal-desc" class="modal-desc"></p>
      <div class="modal-specs"><h5>✦ Especificaciones</h5><div id="modal-specs-content"></div></div>
      <div class="modal-actions">
        <button class="btn-add-cart" onclick="addFromModal()">🛒 Agregar al carrito</button>
      </div>
    </div>
  </div>
</div>

<!-- CART PANEL -->
