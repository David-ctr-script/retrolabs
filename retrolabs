};

const PRODUCTS = {
  'mido-teal': {
    imgs: [IMGS.mido_teal],
    thumb: IMGS.mido_teal,
    badge:'Relojes', badgeClass:'badge-relojes',
    title:'Commander I — Aqua', brand:'Mido · Swiss Made Since 1959',
