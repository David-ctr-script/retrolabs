    desc:'El Mido Commander lleva más de 60 años siendo ícono de la relojería suiza. Este modelo con esfera aqua-teal es moderno, elegante y destaca en cualquier outfit. Movimiento automático Caliber 80 con hasta 80 horas de reserva de marcha. Ideal para quien quiere suizo de verdad sin gastar una fortuna. Envío incluido, llega en 7 días aprox.',
    specs:[['Marca','Mido (Swiss Made)'],['Modelo','Commander I'],['Movimiento','Automático Caliber 80'],['Reserva','80 horas'],['Cristal','Zafiro biselado'],['Agua','50 m / 165 ft'],['Diámetro','40 mm'],['Envío','Incluido ~7 días']]
  },
  'mido-rose': {
    imgs: [IMGS.mido_rose],
    thumb: IMGS.mido_rose,
    badge:'Relojes', badgeClass:'badge-relojes',
    title:'Commander II — Rose Gold', brand:'Mido · Swiss Made Since 1959',
    priceMXN:1850, priceUSD:92,
    desc:'La versión Rose Gold del Commander II combina la elegancia clásica suiza con un tono cálido perfecto para ocasiones especiales. Movimiento automático certificado por el COSC. Un reloj de lujo accesible con acabado PVD en rosa dorado. Envío incluido, llega en 7 días aprox.',
    specs:[['Marca','Mido (Swiss Made)'],['Modelo','Commander II'],['Movimiento','Automático Caliber 80'],['Certificación','COSC Chronometer'],['Acabado','PVD Rose Gold'],['Cristal','Zafiro biselado'],['Agua','50 m / 165 ft'],['Envío','Incluido ~7 días']]
  },
  'rolex-gmt': {
    imgs: [IMGS.rolex_frontal, IMGS.rolex_caja, IMGS.rolex_corona],
    thumb: IMGS.rolex_frontal,
    badge:'Lujo', badgeClass:'badge-lujo',
    title:'GMT-Master II "Sprite"', brand:'Rolex · Oyster Perpetual',
    priceMXN:1300, priceUSD:65,
    desc:'El Rolex GMT-Master II es uno de los relojes más reconocidos del mundo. El "Sprite" con bisel negro-verde es el favorito de pilotos, empresarios y coleccionistas. Esfera negra y manecillas luminosas perfectamente legibles de día y de noche. Brazalete Jubilee de acero inoxidable. Una pieza de lujo que habla sin decir palabras. Disponible desde $1,300 MXN.',
    specs:[['Marca','Rolex'],['Modelo','GMT-Master II'],['Referencia','Oyster Perpetual'],['Bisel','Cerachrom Negro-Verde "Sprite"'],['Esfera','Negra con índices luminosos'],['Brazalete','Jubilee acero Oystersteel'],['Corona','Oyster sellada'],['Precio desde','$1,300 MXN']]
  },
  'gorra-barbas': {
    imgs: [IMGS.gorra_star, IMGS.gorra_dragon, IMGS.gorra_interior],
    thumb: IMGS.gorra_star,
    badge:'Gorras', badgeClass:'badge-gorras',
    title:'Barbas Premium — Star Edition', brand:'Barbas Hats · México',
    priceMXN:200, priceUSD:10,
    desc:'La gorra Star Edition de Barbas Hats es uno de los modelos más populares de la marca. Interior dorado satinado, correa premium bordada con el logo "El Barbas Hats", pala de gamuza negra y parche bordado con estrella de pedrería rosa gold. La combinación perfecta de street y lujo casual.',
    specs:[['Marca','Barbas Hats'],['Modelo','Star / Dragon Edition'],['Color','Negro total'],['Pala','Gamuza negra premium'],['Interior','Satinado dorado'],['Parche','Bordado 3D + pedrería rose gold'],['Ajuste','Snap-back ajustable'],['Precio desde','$200 MXN']]
  },
  'acc-correa': {
    imgs: [],
    thumb: '',
    badge:'Accesorios', badgeClass:'badge-accesorios',
    title:'Correa Milanese Mesh — Silver', brand:'RetroLabs · Accesorios',
    priceMXN:350, priceUSD:17,
    desc:'Correa tipo Milanese Mesh de acero inoxidable, compatible con la mayoría de relojes con anclaje de 20mm. Acabado plateado elegante. Compatible con Mido Commander y muchos otros modelos.',
    specs:[['Ancho','20 mm'],['Material','Acero inoxidable 316L'],['Tipo','Milanese Mesh'],['Color','Silver / Plateado'],['Cierre','Magnético ajustable']]
  },
  'acc-estuche': {
    imgs: [],
    thumb: '',
    badge:'Accesorios', badgeClass:'badge-accesorios',
    title:'Estuche de Reloj — Negro', brand:'RetroLabs · Accesorios',
    priceMXN:150, priceUSD:7,
    desc:'Estuche portátil para reloj, interior acolchado en terciopelo negro. Ideal para viajes, regalos o guardar tu reloj de forma segura. Exterior tipo cuero sintético negro.',
    specs:[['Material ext.','Cuero sintético negro'],['Interior','Terciopelo negro acolchado'],['Compatibilidad','Universal (hasta 46mm)']]
  }
};

let currentProduct = null;
let galleryIndex = 0;
let cart = [];
let carouselIndex = 0;
const carouselSlides = document.querySelectorAll('#heroCarousel .carousel-slide');
let carouselTimer;

// CAROUSEL
function initCarousel() {
  const dotsWrap = document.getElementById('carouselDots');
  carouselSlides.forEach((_,i) => {
    const dot = document.createElement('div');
    dot.className = 'carousel-dot' + (i===0?' active':'');
    dot.onclick = () => { goSlide(i); startCarouselTimer(); };
    dotsWrap.appendChild(dot);
  });
  startCarouselTimer();
}
function goSlide(idx) {
  carouselSlides[carouselIndex].classList.remove('active');
  document.querySelectorAll('.carousel-dot')[carouselIndex].classList.remove('active');
  carouselIndex = (idx + carouselSlides.length) % carouselSlides.length;
  carouselSlides[carouselIndex].classList.add('active');
  document.querySelectorAll('.carousel-dot')[carouselIndex].classList.add('active');
}
function startCarouselTimer() {
  clearInterval(carouselTimer);
  carouselTimer = setInterval(() => goSlide(carouselIndex + 1), 5000);
}

// GALLERY (modal)
let galleryStartX = 0;
function buildGallery(imgs) {
  const track = document.getElementById('gallery-track');
  const dotsEl = document.getElementById('gallery-dots');
  const galleryEl = document.getElementById('modal-gallery');
  track.innerHTML = '';
  dotsEl.innerHTML = '';
  galleryIndex = 0;
  if (!imgs || imgs.length === 0) { galleryEl.style.display='none'; return; }
  galleryEl.style.display = 'block';
  imgs.forEach((src,i) => {
    const slide = document.createElement('div');
    slide.className = 'gallery-slide';
    slide.innerHTML = `<img src="${src}" alt="foto ${i+1}">`;
    track.appendChild(slide);
    const dot = document.createElement('button');
    dot.className = 'gallery-dot' + (i===0?' active':'');
    dot.onclick = () => setGallery(i);
    dotsEl.appendChild(dot);
  });
  track.style.transform = 'translateX(0)';
  // swipe support
  const g = galleryEl;
  g.addEventListener('touchstart', e => { galleryStartX = e.touches[0].clientX; }, {passive:true});
  g.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - galleryStartX;
    if (Math.abs(dx) > 40) galleryMove(dx < 0 ? 1 : -1);
  });
}
function setGallery(idx) {
  const imgs = currentProduct.imgs;
  galleryIndex = (idx + imgs.length) % imgs.length;
  document.getElementById('gallery-track').style.transform = `translateX(-${galleryIndex*100}%)`;
  document.querySelectorAll('.gallery-dot').forEach((d,i) => d.classList.toggle('active', i===galleryIndex));
}
function galleryMove(dir) { setGallery(galleryIndex + dir); }

// MODAL
function openModal(id) {
  const p = PRODUCTS[id];
  if (!p) return;
  currentProduct = {id, ...p};
  buildGallery(p.imgs);
  const badgeTop = document.getElementById('modal-badge-top');
  badgeTop.className = 'modal-badge ' + p.badgeClass;
  badgeTop.textContent = p.badge;
  document.getElementById('modal-title').textContent = p.title;
  document.getElementById('modal-brand').textContent = p.brand;
  document.getElementById('modal-price-mxn').textContent = '$' + p.priceMXN.toLocaleString('es-MX') + ' MXN';
  document.getElementById('modal-price-usd').textContent = '≈ $' + p.priceUSD + ' USD';
  document.getElementById('modal-desc').textContent = p.desc;
  document.getElementById('modal-specs-content').innerHTML = p.specs.map(([k,v]) => `<div class="spec-row"><span class="spec-key">${k}</span><span class="spec-val">${v}</span></div>`).join('');
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
}
function closeModalIfOuter(e) { if (e.target===document.getElementById('modal-overlay')) closeModal(); }
function addFromModal() { if (!currentProduct) return; addToCart(currentProduct); closeModal(); }

// CART
function addToCart(product) {
  const existing = cart.find(i => i.id===product.id);
  if (existing) existing.qty++;
  else cart.push({...product, qty:1});
  updateCartUI();
  openCart();
}
function removeFromCart(id) { cart = cart.filter(i => i.id!==id); updateCartUI(); }
function updateCartUI() {
  const count = cart.reduce((s,i) => s+i.qty, 0);
  const countEl = document.getElementById('cart-count');
  if (count>0) { countEl.textContent=count; countEl.classList.add('show'); } else countEl.classList.remove('show');
  document.getElementById('cart-total').textContent = '$' + cart.reduce((s,i)=>s+i.priceMXN*i.qty,0).toLocaleString('es-MX') + ' MXN';
  const listEl = document.getElementById('cart-items-list');
  if (cart.length===0) { listEl.innerHTML='<div class="cart-empty"><div class="cart-empty-icon">🛒</div>Tu carrito está vacío.</div>'; return; }
  listEl.innerHTML = cart.map(item => `
    <div class="cart-item">
      ${item.thumb ? `<img src="${item.thumb}" class="cart-item-img" alt="${item.title}">` : `<div class="cart-item-img" style="background:#F0EDE8;display:flex;align-items:center;justify-content:center;font-size:24px;">⌚</div>`}
      <div class="cart-item-info">
        <div class="cart-item-name">${item.title}${item.qty>1?` <span style="color:var(--gold-dark);font-size:11px;">x${item.qty}</span>`:''}</div>
        <div class="cart-item-price">$${(item.priceMXN*item.qty).toLocaleString('es-MX')} MXN</div>
      </div>
      <button class="cart-item-remove" onclick="removeFromCart('${item.id}')">✕</button>
    </div>`).join('');
}
function toggleCart() { document.getElementById('cart-panel').classList.toggle('open'); }
function openCart() { document.getElementById('cart-panel').classList.add('open'); }
function checkoutWsp() {
  if (!cart.length) { alert('Agrega productos al carrito primero.'); return; }
  const total = cart.reduce((s,i)=>s+i.priceMXN*i.qty,0);
  let msg = 'Hola RetroLabs! 👋 Quiero hacer un pedido:\n\n';
  cart.forEach(i => msg += `• ${i.title} x${i.qty} = $${(i.priceMXN*i.qty).toLocaleString('es-MX')} MXN\n`);
  msg += `\n💰 *Total: $${total.toLocaleString('es-MX')} MXN*\n\n¿Tienen disponibilidad?`;
  window.open('https://wa.me/529613041210?text=' + encodeURIComponent(msg), '_blank');
}

// SEARCH/FILTER
let activeFilter = 'all';
function setFilter(cat, btn) {
  activeFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  filterProducts();
}
function filterProducts() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  document.querySelectorAll('.product-card').forEach(card => {
    const catMatch = activeFilter==='all' || card.dataset.category===activeFilter;
    const queryMatch = !q || card.textContent.toLowerCase().includes(q);
    card.style.display = (catMatch && queryMatch) ? '' : 'none';
  });
  document.querySelectorAll('.category-section').forEach(sec => {
    const visible = [...sec.querySelectorAll('.product-card')].filter(c=>c.style.display!=='none').length;
    sec.style.display = visible ? '' : 'none';
  });
}

// PEDIDO
function enviarPedido() {
  const nombre = document.getElementById('ped-nombre').value.trim();
  const producto = document.getElementById('ped-producto').value.trim();
  if (!nombre || !producto) { alert('Por favor completa tu nombre y el producto de interés.'); return; }
  const tel = document.getElementById('ped-tel').value.trim();
  const ciudad = document.getElementById('ped-ciudad').value.trim();
  const tipo = document.getElementById('ped-tipo').value;
  const comentario = document.getElementById('ped-comentario').value.trim();
  let msg = 'Hola RetroLabs! 👋 Quiero hacer un pedido:\n\n';
  msg += `👤 *Nombre:* ${nombre}\n`;
  if (tel) msg += `📱 *Teléfono:* ${tel}\n`;
  if (ciudad) msg += `📍 *Ciudad:* ${ciudad}\n`;
  if (tipo) msg += `🛒 *Tipo:* ${tipo}\n`;
  msg += `\n📦 *Productos:*\n${producto}\n`;
  if (comentario) msg += `\n💬 *Notas:* ${comentario}\n`;
  window.open('https://wa.me/529613041210?text=' + encodeURIComponent(msg), '_blank');
}

// REVEAL
const observer = new IntersectionObserver(entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }), {threshold:.1,rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

document.addEventListener('keydown', e => { if (e.key==='Escape') closeModal(); });

initCarousel();
</script>
